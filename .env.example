# ═══════════════════════════════════════════════════════════
# DeepSeek LLM 配置（必填）
# ═══════════════════════════════════════════════════════════
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEMPERATURE=0.3

# ═══════════════════════════════════════════════════════════
# 嵌入模型配置（可选，默认使用本地 BGE 中文模型）
# provider 可选: huggingface | openai | dashscope
# ═══════════════════════════════════════════════════════════
EMBEDDING_PROVIDER=huggingface
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_BASE_URL=

# ═══════════════════════════════════════════════════════════
# 多租户 / 会话
# ═══════════════════════════════════════════════════════════
THREAD_ID=default
USER_ID=default_user
TENANT_ID=default_tenant

# ═══════════════════════════════════════════════════════════
# 工作流
# ═══════════════════════════════════════════════════════════
MAX_ITERATIONS=3

# ═══════════════════════════════════════════════════════════
# 记忆系统
# ═══════════════════════════════════════════════════════════
ENABLE_MEMORY=true
SHORT_TERM_TTL_SECONDS=604800
SHORT_TERM_MAX_MESSAGES=30
SHORT_TERM_SUMMARY_THRESHOLD=20
SHORT_TERM_BACKEND=postgres
LONG_TERM_BACKEND=postgres
LONG_TERM_SCOPE=user
SAVE_CONVERSATION_TASK=false
CHECKPOINTER_BACKEND=auto
ENABLE_MILVUS=true
MEMORY_TOP_K=6

# ═══════════════════════════════════════════════════════════
# 基础设施连接
# ═══════════════════════════════════════════════════════════
REDIS_URL=
POSTGRES_DSN=
MILVUS_HOST=
MILVUS_PORT=19530
MILVUS_COLLECTION=mult_agent_memory

# ═══════════════════════════════════════════════════════════
# 其他
# ═══════════════════════════════════════════════════════════
NO_COLOR=
WORKSPACE_DIR=/workspace
